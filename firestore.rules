rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isCrustUser() {
      return request.auth != null
        && (
          (request.auth.token.email != null
            && request.auth.token.email.matches('^.+@crust\\.no$')) ||
          (request.auth.token.preferred_username != null
            && request.auth.token.preferred_username.matches('^.+@crust\\.no$'))
        );
    }

    match /jobApplications/{docId} {
      allow create: if true;
      allow read, update, delete: if isCrustUser();
    }

    match /eventRequests/{docId} {
      allow create: if true;
      allow read, delete: if isCrustUser();
      allow update: if false;
    }

    match /forms/{docId} {
      allow read: if true;
      allow create, update, delete: if isCrustUser();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if isCrustUser();
    }

    match /jobPortalWaitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if isCrustUser();
    }

    match /formSubmissions/{docId} {
      allow create: if true;
      allow read, delete: if isCrustUser();
      allow update: if isCrustUser();
    }

    match /formRemarks/{docId} {
      allow create, read, update, delete: if isCrustUser();
    }

    match /formSubmissionReceipts/{docId} {
      allow get: if true;
      allow list: if false;
      allow create: if true;
      allow update, delete: if isCrustUser();
    }

    match /publications/{docId} {
      allow read: if true;
      allow create, update, delete: if isCrustUser();
    }

    match /locations/{docId} {
      allow read: if true;
      allow create, update, delete: if isCrustUser();
    }

    match /suppliers/{docId} {
      allow read: if isCrustUser();
      allow create, update, delete: if isCrustUser();
    }

    match /integrations/{docId} {
      allow read: if isCrustUser();
      allow create, update, delete: if false;
    }

    match /employees/{docId} {
      allow read: if isCrustUser();
      allow create, update: if isCrustUser();
      allow delete: if false;
    }

    match /orderConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isCrustUser();
    }

    match /orders/{docId} {
      allow create: if true;
      allow read, update: if true;
      allow delete: if isCrustUser();
    }

    match /zettlePrivate/{docId} {
      allow read, write: if false;
    }

    match /zettleOAuthStates/{docId} {
      allow read, write: if false;
    }

    match /plandayPrivate/{docId} {
      allow read, write: if false;
    }

    match /plandayOAuthStates/{docId} {
      allow read, write: if false;
    }

    match /smsHistory/{docId} {
      allow read, create: if isCrustUser();
      allow update, delete: if false;
    }

    match /inventoryUpdates/{docId} {
      allow read, write: if isCrustUser();
    }

    match /phoneEmails/{docId} {
      allow create, update: if true;
      allow read, delete: if isCrustUser();
    }

    match /submissionErrors/{docId} {
      allow create: if true;
      allow read, delete: if isCrustUser();
    }

    match /cateringRequests/{docId} {
      allow create: if request.resource.data.deliveryTimestamp is timestamp
        && request.resource.data.deliveryTimestamp >= request.time + duration.value(2, 'd');
      allow read, update, delete: if isCrustUser();
    }

    match /largeOrders/{docId} {
      allow create: if request.resource.data.deliveryTimestamp is timestamp
        && request.resource.data.deliveryTimestamp >= request.time + duration.value(2, 'd');
      allow read, update, delete: if isCrustUser();
    }

    match /priceAuditLog/{docId} {
      allow read, create: if isCrustUser();
      allow update, delete: if false;
    }

    match /photoUploads/{docId} {
      allow create: if true;
      allow read, delete: if isCrustUser();
    }

  }
}
